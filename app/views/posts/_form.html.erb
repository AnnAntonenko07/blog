<%= form_with model: post, class: "post-form" do |f| %>
  <% if post.errors.any? %>
    <div class="form-errors">
      <p><strong><%= post.errors.count %> <%= post.errors.count == 1 ? "помилка" : "помилки" %>:</strong></p>
      <ul>
        <% post.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :title, "Заголовок", class: "form-label" %>
    <%= f.text_field :title, class: "form-input", placeholder: "Введіть заголовок…" %>
  </div>

  <div class="form-group">
    <%= f.label :author, "Автор", class: "form-label" %>
    <%= f.text_field :author, class: "form-input", placeholder: "Ваше ім'я…" %>
  </div>

  <div class="form-group">
    <%= f.label :body, "Текст", class: "form-label" %>
    <%= f.text_area :body, class: "form-input form-textarea", rows: 12,
        placeholder: "Про що хочете написати?" %>
  </div>

  <div class="form-actions">
    <%= f.submit post.new_record? ? "Опублікувати" : "Зберегти зміни", class: "btn btn--primary" %>
    <%= link_to "Скасувати", post.new_record? ? posts_path : post, class: "btn btn--ghost" %>
  </div>
<% end %>
