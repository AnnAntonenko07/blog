<style>
  :root {
    --page-bg: #f7f8fb;
    --surface: #f1f8f6;
    --surface-strong: #ffffff;
    --ink: #1d2433;
    --muted: #647084;
    --line: #d9e1ea;
    --accent: #0f766e;
    --accent-dark: #115e59;
    --danger: #b42318;
    --danger-bg: #fff1f0;
    --shadow: 0 18px 45px rgba(32, 45, 63, 0.1);
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(15, 118, 110, 0.12), transparent 28rem),
      var(--page-bg);
    color: var(--ink);
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .blog-index {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 40px 0 56px;
  }

  .page-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px;
    align-items: end;
    padding: 42px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(241, 248, 246, 0.88));
    box-shadow: var(--shadow);
  }

  .hero-label {
    margin: 0 0 12px;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .hero-title {
    max-width: 720px;
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.5rem, 7vw, 5.6rem);
    font-weight: 500;
    line-height: 0.94;
  }

  .hero-title em {
    color: var(--accent);
    font-style: italic;
  }

  .hero-copy {
    max-width: 560px;
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 1.03rem;
    line-height: 1.7;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 18px;
    border: 1px solid transparent;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 750;
    line-height: 1;
    text-decoration: none;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease, color 160ms ease;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn--primary {
    background: var(--accent);
    color: #ffffff;
  }

  .btn--primary:hover {
    background: var(--accent-dark);
  }

  .btn--ghost {
    border-color: var(--line);
    background: rgba(255, 255, 255, 0.68);
    color: var(--ink);
  }

  .btn--ghost:hover {
    border-color: var(--accent);
    color: var(--accent-dark);
  }

  .btn--danger {
    border-color: #f3c8c3;
    background: var(--danger-bg);
    color: var(--danger);
  }

  .btn--danger:hover {
    border-color: var(--danger);
    background: #ffe4e0;
  }

  .btn--small {
    min-height: 36px;
    padding: 0 14px;
    font-size: 0.88rem;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
    margin-top: 28px;
  }

  .post-card {
    display: flex;
    min-height: 310px;
    flex-direction: column;
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface-strong);
    box-shadow: 0 10px 28px rgba(32, 45, 63, 0.07);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .post-card:hover {
    border-color: rgba(15, 118, 110, 0.45);
    box-shadow: var(--shadow);
    transform: translateY(-4px);
  }

  .post-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 650;
  }

  .post-card__author {
    color: var(--accent-dark);
  }

  .post-card__title {
    margin: 20px 0 12px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.45rem, 3vw, 2rem);
    font-weight: 600;
    line-height: 1.1;
  }

  .post-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .post-card__title a:hover {
    color: var(--accent-dark);
  }

  .post-card__excerpt {
    margin: 0;
    color: var(--muted);
    font-size: 0.98rem;
    line-height: 1.7;
  }

  .post-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: auto;
    padding-top: 24px;
  }

  .empty-state {
    display: grid;
    justify-items: center;
    gap: 18px;
    margin-top: 28px;
    padding: 56px 24px;
    border: 1px dashed var(--line);
    border-radius: 8px;
    background: rgba(241, 248, 246, 0.78);
    text-align: center;
  }

  .empty-state__title {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.7rem, 5vw, 2.6rem);
    font-weight: 500;
  }

  .empty-state__copy {
    max-width: 420px;
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .page-hero {
      grid-template-columns: 1fr;
      align-items: start;
      padding: 32px;
    }

    .posts-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .blog-index {
      width: min(100% - 24px, 1120px);
      padding: 24px 0 40px;
    }

    .page-hero {
      padding: 24px;
    }

    .hero-copy {
      font-size: 0.98rem;
    }

    .posts-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .post-card {
      min-height: 0;
      padding: 20px;
    }

    .post-card__actions,
    .post-card__actions .btn {
      width: 100%;
    }
  }
</style>

<main class="blog-index">
  <header class="page-hero">
    <div>
      <p class="hero-label">Blog</p>
      <h1 class="hero-title">Latest<br><em>posts</em></h1>
      <p class="hero-copy">Fresh notes, essays, and updates from the blog.</p>
    </div>

    <%= link_to "New Post", new_post_path, class: "btn btn--primary" %>
  </header>

  <% if @posts.empty? %>
    <section class="empty-state" aria-label="No posts">
      <h2 class="empty-state__title">No posts yet.</h2>
      <p class="empty-state__copy">No posts yet. Be the first to write one!</p>
      <%= link_to "New Post", new_post_path, class: "btn btn--primary" %>
    </section>
  <% else %>
    <section class="posts-grid" aria-label="Blog posts">
      <% @posts.each do |post| %>
        <article class="post-card">
          <div class="post-card__meta">
            <% if post.author.present? %>
              <span class="post-card__author"><%= post.author %></span>
            <% end %>
            <time datetime="<%= post.created_at.iso8601 %>">
              <%= post.created_at.strftime("%B %-d, %Y") %>
            </time>
          </div>

          <h2 class="post-card__title">
            <%= link_to post.title, post_path(post) %>
          </h2>

          <p class="post-card__excerpt">
            <%= truncate(strip_tags(post.body.to_s), length: 150) %>
          </p>

          <div class="post-card__actions">
            <%= link_to "View", post_path(post), class: "btn btn--ghost btn--small" %>
            <%= link_to "Edit", edit_post_path(post), class: "btn btn--ghost btn--small" %>
            <%= link_to "Delete",
                        post_path(post),
                        method: :delete,
                        data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                        class: "btn btn--danger btn--small" %>
          </div>
        </article>
      <% end %>
    </section>
  <% end %>
</main>
